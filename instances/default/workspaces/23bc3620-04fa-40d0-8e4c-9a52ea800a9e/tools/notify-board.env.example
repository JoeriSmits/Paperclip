# SMTP relay config for notify-board.sh
# Copy to notify-board.env and fill in your values, then source before running:
#   source tools/notify-board.env && tools/notify-board.sh JOEA-123 "Subject" "Body"
#
# Option A: Gmail with app password (free, recommended)
#   1. Enable 2FA on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an app password for "Mail"
#
# Option B: Any SMTP relay (Mailgun free tier, Fastmail, etc.)

export NOTIFY_BOARD_SMTP_HOST="smtp.gmail.com"
export NOTIFY_BOARD_SMTP_PORT="587"
export NOTIFY_BOARD_SMTP_USER="your-email@gmail.com"
export NOTIFY_BOARD_SMTP_PASS="your-app-password"

# Optional overrides
# export NOTIFY_BOARD_TO="email@joeri.dev"
# export NOTIFY_BOARD_FROM="paperclip@joeri.dev"
